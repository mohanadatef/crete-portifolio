{
    "openapi": "3.0.0",
    "info": {
        "title": "Real Estate API Documentation",
        "description": "Real Estate API documentation",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000/api",
            "description": "Local API Server"
        }
