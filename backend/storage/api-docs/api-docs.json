        "/public/leads": {
            "post": {
                "tags": [
                    "Public Leads"
                ],
                "summary": "Submit a new lead",
                "operationId": "314c3537cab4583a43adbddeb9bbf595",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "phone",
                                    "recaptcha_token",
                                    "privacy_consent"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string"
                                    },
                                    "phone": {
                                        "type": "string"
                                    },
                                    "message": {
                                        "type": "string"
                                    },
                                    "project_id": {
                                        "type": "integer"
                                    },
                                    "recaptcha_token": {
                                        "type": "string"
                                    },
                                    "privacy_consent": {
                                        "type": "boolean"
                                    },
                                    "utm_source": {
                                        "type": "string"
                                    },
                                    "utm_medium": {
                                        "type": "string"
                                    },
                                    "utm_campaign": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Lead created successfully"
                    },
                    "422": {
                        "description": "Validation error or Spam check failed"
                    }
                }
            }
        },
