    "paths": {
        "/admin/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login for admin users",
                "operationId": "9222ab366440a6df8e9576bc12612962",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "password": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful"
                    },
                    "401": {
                        "description": "Invalid credentials"
                    }
                }
            }
        },
        "/public/blog/categories": {
            "get": {
                "tags": [
                    "Public Blog"
                ],
                "summary": "Get public blog categories",
                "operationId": "c26417449797311baf694a9d25bf1334",
                "responses": {
                    "200": {
                        "description": "Successful operation"
                    }
                }
            }
        },
        "/public/blog/posts": {
            "get": {
                "tags": [
                    "Public Blog"
                ],
                "summary": "Get public blog posts",
                "operationId": "70775ffaa0f4c3183d76a130f89daac8",
                "responses": {
                    "200": {
                        "description": "Successful operation"
                    }
                }
            }
        },
        "/public/blog/posts/{slug}": {
            "get": {
                "tags": [
                    "Public Blog"
                ],
                "summary": "Get a specific blog post by slug",
                "operationId": "dff084a674678b27163b1664743ae4c0",
                "parameters": [
                    {
                        "name": "slug",
                        "in": "path",
                        "description": "Blog post slug",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful operation"
                    },
                    "404": {
                        "description": "Blog post not found"
                    }
                }
            }
        },
        "/public/leads": {
            "post": {
                "tags": [
                    "Public Leads"
                ],
                "summary": "Submit a new lead",
                "operationId": "6b31c89255c8d363254be3a7de83b6cd",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "phone",
                                    "recaptcha_token",
                                    "privacy_consent"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string"
                                    },
                                    "phone": {
                                        "type": "string"
                                    },
                                    "message": {
                                        "type": "string"
                                    },
                                    "project_id": {
                                        "type": "integer"
                                    },
                                    "recaptcha_token": {
                                        "type": "string"
                                    },
                                    "privacy_consent": {
                                        "type": "boolean"
                                    },
                                    "utm_source": {
                                        "type": "string"
                                    },
                                    "utm_medium": {
                                        "type": "string"
                                    },
                                    "utm_campaign": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Lead created successfully"
                    },
                    "422": {
                        "description": "Validation error or Spam check failed"
                    }
                }
            }
        },
